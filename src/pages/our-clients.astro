---
import { getEmDashEntry, getSeoMeta } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { detectLocale, SITE_TITLES } from "../utils/i18n";

const locale = detectLocale(Astro.url.pathname);
const slug = "our-clients";
const { entry: page, cacheHint } = await getEmDashEntry("pages", slug, { locale });
if (!page) return Astro.redirect("/404");
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const siteTitle = SITE_TITLES[locale];
const seo = getSeoMeta(page, { siteTitle, siteUrl: Astro.url.origin, path: `/${slug}` });
---

<Base title={seo.title} pageTitle={seo.ogTitle} description={seo.description} canonical={seo.canonical} content={{ collection: "pages", id: page.data.id, slug }}>
  <section class="page-hero"><div class="container"><h1>{page.data.title}</h1></div></section>
  <section class="section"><div class="container"><div class="content-block"><PortableText value={page.data.content} /></div></div></section>
  <div style="margin:2rem auto;max-width:1100px;padding:0 1.5rem">
    <h2 style="text-align:center">專案圖片</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1rem;justify-items:center;max-width:960px;margin:0 auto">
      <img src="/2.-HSBC-Building-Fanling-150A-Auto-changeover-contactor-at-main-switchboard-2-r2qah3tvyz1urk7phe3dnb7p3lmutqvk1or5wqzh90.jpg" style="width:100%;height:250px;object-fit:cover;border-radius:8px" loading="lazy" />
      <img src="/P2130002-scaled-r2qah3twc4pdxr1klpcqiv90ma1zz44xd4cti3uin8.jpg" style="width:100%;height:250px;object-fit:cover;border-radius:8px" loading="lazy" />
      <img src="/Inspection-1-scaled-e1736498471313-1024x683.jpg" style="width:100%;height:250px;object-fit:cover;border-radius:8px" loading="lazy" />
      <img src="/Viewco-website-bay-photo-wmremove.jpeg" style="width:100%;height:250px;object-fit:cover;border-radius:8px" loading="lazy" />
      <img src="/Viewco-website-HKSP-photo-wmremove.jpeg" style="width:100%;height:250px;object-fit:cover;border-radius:8px" loading="lazy" />
      <img src="/Data-Record-6-scaled-e1736497744306.jpg" style="width:100%;height:250px;object-fit:cover;border-radius:8px" loading="lazy" />
    </div>
  </div>
</Base>
