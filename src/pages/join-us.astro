---
import Base from "../layouts/Base.astro";
const t = {
  pageTitle: "加入我們",
  heroTitle: "Join Our Team",
  heroSub: "加入我們，共創未來",
  sections: [
    {
      title: "Career",
      subtitle: "與我們一同成長，共創未來",
      content: "偉保工程有限公司，成立於1984年，是香港建築業的佼佼者。我們不僅見證了香港的歷史變遷，更在建築和工程領域中留下深刻的足跡。"
    },
    {
      title: "Our Expertise",
      subtitle: "我們的專業領域",
      content: null,
      subsections: [
        { title: "空調系統", text: "我們擁有豐富的經驗，致力於為客戶提供高效、可靠的空調和通風方案。" },
        { title: "通風系統", text: "從設計到安裝，我們的專家團隊將確保您的抽氣系統運作良好，以確保室內空氣品質。" },
        { title: "改建和維護", text: "我們協助客戶進行建築改建和現有系統的維護，以確保其長期運作。" }
      ]
    },
    {
      title: "我們的價值觀",
      content: "如果你熱愛建築和工程，並渴望在一個充滿挑戰和機會的環境中發展，歡迎加入我們的團隊！請將履歷發送至 engineering@viewco.com.hk 以獲取更多資訊。"
    },
    {
      title: "Apply Now",
      subtitle: "申請職位",
      content: "請填寫以下表格，我們的人力資源團隊將盡快與你聯絡。"
    }
  ]
};
---
<Base title={t.pageTitle} description={t.heroSub}>
  <section class="page-hero" style="background:url(/Viewco-website-HKSP-photo-wmremove-1.jpeg) center/cover;min-height:50vh">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#090a1ad9,#090a1a99,#090a1ad9);z-index:1"></div>
    <div class="container" style="position:relative;z-index:2">
      <span class="section-subtitle" style="color:#fa4729">Careers</span>
      <h1 style="font-size:3em">{t.heroTitle}</h1>
      <p style="font-size:1.2rem">{t.heroSub}</p>
    </div>
  </section>

  <!-- Join Us Poster Image -->
  <section class="section" style="padding:2rem 0;background:#fff">
    <div class="container" style="text-align:center">
      <img src="/Viewco-website-HKSP-photo-wmremove.jpeg" alt="Join Our Team" style="max-width:100%;height:auto;border-radius:8px;box-shadow:0 4px 24px rgba(0,0,0,.1)" loading="lazy" />
    </div>
  </section>

  <section class="section"><div class="container"><div class="content-block">
    {t.sections.slice(0,3).map(s => (
      <div class="accordion-item">
        <h3 class="accordion-header" data-accordion-trigger>
          <span class="accordion-arrow">▶</span> {s.title}
          {s.subtitle && <small class="accordion-subtitle"> — {s.subtitle}</small>}
        </h3>
        <div class="accordion-body">
          {s.content && <p>{s.content}</p>}
          {s.subsections && s.subsections.map(sub => (
            <div style="margin-bottom:1rem">
              <h4 style="color:#181d4e;font-weight:500;margin-bottom:.25rem">{sub.title}</h4>
              <p style="margin:0">{sub.text}</p>
            </div>
          ))}
        </div>
      </div>
    ))}

    <!-- Apply Now section always open -->
    <div class="accordion-item">
      <h3 class="accordion-header open" data-accordion-trigger>
        <span class="accordion-arrow">▼</span> {t.sections[3].title}
        <small class="accordion-subtitle"> — {t.sections[3].subtitle}</small>
      </h3>
      <div class="accordion-body" style="display:block">
        <p>{t.sections[3].content}</p>
        <form class="contact-form" style="margin-top:1.5rem">
          <div class="form-group"><label>申請職位</label><input type="text" name="position" required placeholder="申請職位" /></div>
          <div class="form-group"><label>姓名</label><input type="text" name="name" required placeholder="姓名" /></div>
          <div class="form-group"><label>電郵</label><input type="email" name="email" required placeholder="email@example.com" /></div>
          <div class="form-group"><label>電話</label><input type="tel" name="phone" placeholder="+852" /></div>
          <div class="form-group"><label>履歷（只接受PDF）</label><input type="file" name="resume" accept=".pdf" /></div>
          <div class="form-group"><label><input type="checkbox" required /> 我同意收集並儲存我提交的數據（<a href="/privacy/">私隱聲明和免責聲明</a>）</label></div>
          <button type="submit" class="btn-submit">提交申請</button>
        </form>
      </div>
    </div>
  </div></div></section>

  <style>
    .accordion-item { margin-bottom: .75rem; border: 1px solid #e0e0e0; border-radius: 6px; overflow: hidden; }
    .accordion-header { cursor: pointer; padding: 1rem 1.25rem; margin: 0; font-size: 1.1rem; font-weight: 500; color: #181d4e; background: #fafafa; display: flex; align-items: center; gap: .5rem; user-select: none; transition: background .2s; }
    .accordion-header:hover { background: #f0f0f0; }
    .accordion-header .accordion-subtitle { font-weight: 400; color: #888; font-size: .85rem; }
    .accordion-arrow { display: inline-block; transition: transform .25s; font-size: .75rem; width: 16px; text-align: center; flex-shrink: 0; }
    .accordion-header.open .accordion-arrow { transform: rotate(90deg); }
    .accordion-body { display: none; padding: 1rem 1.25rem 1.25rem 2.5rem; background: #fff; }
    .accordion-body p { margin-bottom: .75rem; line-height: 1.8; color: #444; }
    .contact-form { display: flex; flex-direction: column; gap: 1rem; max-width: 600px; }
    .form-group { display: flex; flex-direction: column; gap: .25rem; }
    .form-group label { font-size: .9rem; font-weight: 500; color: #333; }
    .form-group input[type="text"], .form-group input[type="email"], .form-group input[type="tel"] { padding: .7rem .9rem; border: 1px solid #ccc; border-radius: 4px; font-size: .95rem; }
    .form-group input[type="checkbox"] { width: auto; margin-right: .5rem; }
    .btn-submit { background: #fa4729; color: #fff; border: none; padding: .8rem 2rem; font-size: 1rem; font-weight: 500; border-radius: 4px; cursor: pointer; transition: opacity .2s; align-self: flex-start; }
    .btn-submit:hover { opacity: .8; }
    @media (max-width: 767px) { .accordion-body { padding-left: 1.5rem; } }
  </style>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      document.querySelectorAll("[data-accordion-trigger]").forEach(h => {
        h.addEventListener("click", () => {
          const b = h.nextElementSibling, o = b.style.display === "block";
          b.style.display = o ? "none" : "block";
          h.classList.toggle("open", !o);
          const a = h.querySelector(".accordion-arrow");
          if (a) a.textContent = o ? "▶" : "▼";
        });
      });
    });
  </script>
</Base>
