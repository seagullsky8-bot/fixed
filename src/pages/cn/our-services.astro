---
import Base from "../../layouts/Base.astro";
const t = {
  pageTitle: "服务内容",
  heroTitle: "Our Services",
  heroSub: "提供全面专业的机电工程服务",
  intro: "伟保是一间提供香港机电工程服务承建商，包括空调及通风及抽气系统的安装，改建维护及保养工程。",
  services: [
    {
      title: "项目管理",
      content: "伟保善长于提供专业设计和建设包括机械通风及空调，电气，项目管理和业务连续性建构等项目，我们多年来所拥有的丰富经验加上宝贵的工程技朮溶入于设计创建方面尤其著名，而且当中更会确保整个设计及建筑的可持续性及可维护性。通过所有设计及施工阶段可以充分反映我们所应用到的专业知识。我们在提供创新的空调及通风系统，不仅提高建筑物的运营效率和能源效益，同时也提升了客户的生活和工作条件及所享受到的舒适经验。",
      images: ["/P2130002-scaled-r2qah3twc4pdxr1klpcqiv90ma1zz44xd4cti3uin8.jpg"],
      alts: ["项目管理现场"]
    },
    {
      title: "维修及保养",
      content: "伟保工程有限公司专门提供于商业楼宇，办公室，餐厅和住宅专业空调的定期保养，维修，销售和安装。",
      images: ["/Machine-1600x1200-1.jpg", "/Inspection-1-scaled-e1736498471313-1024x683.jpg"],
      alts: ["机组设备", "设备检查维修"]
    },
    {
      title: "室内装修",
      content: "我们善长于项目管理，提供由最初设计概念至项目完成的一站式服务，设计范畴包括住宅、餐厅及办公室等。我们的工作是聆听客户之需要，提供适时及合乎经济效益的方案。与客户敲定设计方向及方案后，我们的设计及承建团队会共同合作，于合理时间及成本控制内完成整个项目，而在过程的每一步，我们极重视与客户的紧密沟通。",
      images: ["/panorama-3323163_1920.jpg", "/IMG_1588-1290x725.jpg", "/IMG_1283-1290x725.jpg"],
      alts: ["室内装修全景", "装修工程细节", "完工项目实景"]
    }
  ],
  summaryTitle: "服务项目摘要",
  summaryList: [
    "室内装修项目", "水泵大修", "冷水机及冷却塔大修", "风柜更换工程",
    "年度检查证书 (消防署)", "冷气清洗服务", "电力安装及 WR2 检查",
    "冷水机安装及更换", "通风系统安装及更换", "VRV 安装及更换", "冻仓安装工程"
  ]
};
---
<Base title={t.pageTitle} description={t.heroSub}>
  <section class="page-hero">
    <div class="container">
      <span class="section-subtitle">Services</span>
      <h1>{t.heroTitle}</h1>
      <p>{t.heroSub}</p>
    </div>
  </section>

  <section class="section" style="padding-bottom:0">
    <div class="container">
      <div class="section-title">
        <h2>What We Do</h2>
        <p class="section-desc">{t.intro}</p>
      </div>
    </div>
  </section>

  <section class="services-section">
    <div class="container">
      <div class="services-grid">
        {t.services.map(s => (
          <div class={`service-card${s.images.length > 1 ? ' service-card--wide' : ''}`}>
            <div class="service-card__image" style="cursor:pointer">
              {s.images.map((img, i) => (
                <a href={img} target="_blank"><img src={img} alt={s.alts[i]} loading="lazy" /></a>
              ))}
            </div>
            <div class="service-card__content">
              <h3>{s.title}</h3>
              <p>{s.content}</p>
            <a href="/our-services/" class="service-card__link">Read More &rarr;</a>`n            </div>`n          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="section-title" style="margin-bottom:2rem">
        <h2 style="color:#fff">{t.summaryTitle}</h2>
      </div>
      <div class="summary-grid">
        {t.summaryList.map(item => (
          <div class="summary-item">{item}</div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .service-card--wide .service-card__image {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .summary-item {
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 6px;
    color: #fff;
    font-size: .95rem;
    text-align: center;
    transition: background .3s, border-color .3s;
  }
  .summary-item:hover {
    background: rgba(255,255,255,.12);
    border-color: #fa4729;
  }
  @media (max-width: 1023px) {
    .services-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .summary-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 767px) {
    .services-grid { grid-template-columns: 1fr !important; }
    .summary-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
