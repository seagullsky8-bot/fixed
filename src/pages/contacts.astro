---
import Base from "../layouts/Base.astro";
import { detectLocale, SITE_TITLES, SITE_TAGLINES } from "../utils/i18n";

const locale = detectLocale(Astro.url.pathname);
const siteTitle = SITE_TITLES[locale];
const siteTagline = SITE_TAGLINES[locale];

const content = {
  "zh-Hant": {
    pageTitle: "聯絡我們",
    heroTitle: "Contact Us",
    heroSub: "隨時歡迎與我們聯絡",
    addressLabel: "總公司",
    address: "中國香港 九龍 九龍灣宏泰道12號 榮發工業大廈7樓711-713室",
    mapEmbedUrl: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3691.5!2d114.216!3d22.3285!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3404015d5c3c5c01%3A0x1234567890abcdef!2sWing+Fat+Industrial+Building!5e0!3m2!1sen!2shk!4v1700000000000!5m2!1sen!2shk"
  },
  "zh-Hans": {
    pageTitle: "联系我们",
    heroTitle: "Contact Us",
    heroSub: "随时欢迎与我们联络",
    addressLabel: "总公司",
    address: "中国香港 九龙 九龙湾宏泰道12号 荣发工业大厦7楼711-713室",
    mapEmbedUrl: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3691.5!2d114.216!3d22.3285!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3404015d5c3c5c01%3A0x1234567890abcdef!2sWing+Fat+Industrial+Building!5e0!3m2!1sen!2shk!4v1700000000000!5m2!1sen!2shk"
  },
  "en": {
    pageTitle: "Contact Us",
    heroTitle: "Contact Us",
    heroSub: "Always Welcome to Contact Us",
    addressLabel: "Head Office",
    address: "Unit 711-713, 7/F, Wing Fat Industrial Building, 12 Wang Tai Road, Kowloon Bay, Hong Kong",
    mapEmbedUrl: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3691.5!2d114.216!3d22.3285!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3404015d5c3c5c01%3A0x1234567890abcdef!2sWing+Fat+Industrial+Building!5e0!3m2!1sen!2shk!4v1700000000000!5m2!1sen!2shk"
  }
};

const t = content[locale] || content["zh-Hant"];
---

<Base title={t.pageTitle} pageTitle={`${t.pageTitle} — ${siteTitle}`} description={siteTagline}>
  <section class="page-hero">
    <div class="container">
      <span class="section-subtitle">Get in Touch</span>
      <h1>{t.heroTitle}</h1>
      <p>{t.heroSub}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contacts-grid">
        <!-- Info -->
        <div class="contacts-info">
          <h2 style="color:#181d4e;margin-bottom:1.5rem">{t.addressLabel}</h2>
          <address style="font-style:normal;line-height:2;color:#444;margin-bottom:1.5rem">
            <p style="font-size:1.05rem;font-weight:500;color:#181d4e;margin-bottom:.25rem">{t.address}</p>
          </address>
          <div class="contact-links">
            <a href="tel:+85225430610">📞 +852 25430610</a>
            <a href="https://wa.me/85290218198" target="_blank" rel="noopener">💬 WhatsApp: +852 90218198</a>
            <a href="tel:+85228153681">📠 +852 28153681</a>
            <a href="mailto:engineering@viewco.com.hk">✉️ engineering@viewco.com.hk</a>
          </div>
        </div>

        <!-- Map -->
        <div class="contacts-map">
          <iframe
            src={t.mapEmbedUrl}
            width="100%"
            height="100%"
            style="border:0;border-radius:8px;min-height:350px"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="VIEWCO Office Location"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contacts-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 2.5rem;
    align-items: start;
  }
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .contact-links a {
    display: block;
    padding: .75rem 1rem;
    background: #f5f5f5;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    color: #181d4e !important;
    font-size: .95rem;
    text-decoration: none;
    transition: all .3s;
  }
  .contact-links a:hover {
    background: #e8e8e8;
    border-color: #fa4729;
    color: #fa4729 !important;
  }
  @media (max-width: 767px) {
    .contacts-grid { grid-template-columns: 1fr; }
    .contacts-map { min-height: 300px; }
  }
</style>
