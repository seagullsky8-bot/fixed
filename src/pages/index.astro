---
import Base from "../layouts/Base.astro";
import { detectLocale, SITE_TITLES, SITE_TAGLINES } from "../utils/i18n";

const locale = detectLocale(Astro.url.pathname);
const siteTitle = SITE_TITLES[locale];
const siteTagline = SITE_TAGLINES[locale];
const homeUrl = locale === "zh-Hant" ? "/" : `/${locale === "zh-Hans" ? "cn" : "en"}/`;
const servicesUrl = locale === "zh-Hant" ? "/our-services/" : `/${locale === "zh-Hans" ? "cn" : "en"}/our-services/`;

const t = {
  about: "關於偉保 | About VIEWCO",
  heroTitle: "四十年工程卓越的傳奇",
  heroTitleEN: "Four Decades of Engineering Excellence",
  heroText1: "偉保工程有限公司在1984年4月創辦，專注於香港屋宇設備及環保工程服務，包括提供安裝，改建及加建，維修和保養空調及通風系統、電力系統、裝修服務和其他的機電系統設施。",
  heroText1EN: "Founded in April 1984, VIEWCO Engineering Co., Ltd. specializes in Hong Kong building services and environmental engineering, including installation, A&A, maintenance and repair of AC, ventilation, electrical systems and interior fit-out.",
  heroText2: "我們致力於提供卓越的技術，全面高質量的服務從而滿足客戶的需求。我們的專業服務取得 ISO9001:2015，ISO14000:2015 及 ISO45001:2018 國際標準的認證。",
  heroText2EN: "We are dedicated to providing technical excellence and comprehensive quality services. Our professional services are certified to ISO 9001:2015, ISO 14001:2015 and ISO 45001:2018.",
  servicesTitle: "業務服務內容",
  servicesTitleEN: "Our Business Services",
  servicesDesc: "偉保是一間提供香港機電工程服務承建商，包括空調及通風及抽氣系統的安裝，改建維護及保養工程。",
  servicesDescEN: "VIEWCO is a Hong Kong E&M engineering service contractor specializing in AC, ventilation and exhaust systems.",
  card1Title: "項目管理", card1TitleEN: "Project Management", card1Desc: "超過四十年的專業經驗", card1DescEN: "Over 40 Years of Professional Experience",
  card2Title: "維修及保養", card2TitleEN: "Maintenance & Repair", card2Desc: "為客戶提供可靠的保障", card2DescEN: "Reliable Protection for Our Clients",
  card3Title: "室內裝修", card3TitleEN: "Interior Fit-Out", card3Desc: "創造完美的室內空間與空調規劃", card3DescEN: "Creating Perfect Interior Spaces with AC Planning",
  qualityTitle: "高質量的服務",
  qualityTitleEN: "Quality Service",
  qualityText: "專業及經驗豐富的偉保團隊致力提供最優質服務以符合香港政府所有法定要求和職業安全及健康標準。",
  qualityTextEN: "Our professional and experienced VIEWCO team is dedicated to providing the highest quality services in compliance with all Hong Kong Government statutory requirements and occupational safety and health standards.",
  readMore: "閱讀更多 | Read More",
};
---

<Base title={siteTitle} description={siteTagline}>
  <section class="hero-section" data-astro-cid-j7pv25f6>
    <div class="hero-section__bg" data-astro-cid-j7pv25f6></div>
    <div class="hero-section__overlay" data-astro-cid-j7pv25f6></div>
    <div class="hero-section__content" data-astro-cid-j7pv25f6>
      <h1 class="hero-section__title" data-astro-cid-j7pv25f6>{t.about}</h1>
      <p class="hero-section__text" data-astro-cid-j7pv25f6 style="font-size:1.4rem;font-weight:600;color:var(--white)">{t.heroTitle}</p>
      <p class="hero-section__text" data-astro-cid-j7pv25f6 style="font-size:.95rem;color:var(--white-40);font-style:italic">{t.heroTitleEN}</p>
      <p class="hero-section__text" data-astro-cid-j7pv25f6>{t.heroText1}</p>
      <p class="hero-section__text" data-astro-cid-j7pv25f6 style="color:rgba(255,255,255,.45);font-size:.9rem;font-style:italic">{t.heroText1EN}</p>
      <p class="hero-section__text" data-astro-cid-j7pv25f6>{t.heroText2}</p>
      <p class="hero-section__text" data-astro-cid-j7pv25f6 style="color:rgba(255,255,255,.45);font-size:.9rem;font-style:italic">{t.heroText2EN}</p>
    </div>
  </section>

  <section class="services-section" data-astro-cid-j7pv25f6>
    <div class="section-title" data-astro-cid-j7pv25f6>
      <span class="section-subtitle" data-astro-cid-j7pv25f6>{t.servicesTitleEN}</span>
      <h2 data-astro-cid-j7pv25f6>{t.servicesTitle}</h2>
      <p class="section-desc" data-astro-cid-j7pv25f6>{t.servicesDesc}</p>
      <p class="section-desc" data-astro-cid-j7pv25f6 style="color:var(--body-light);font-size:.9rem;font-style:italic">{t.servicesDescEN}</p>
    </div>
    <div class="services-grid" data-astro-cid-j7pv25f6>
      <a href={servicesUrl} class="service-card" style="text-decoration:none;color:inherit" data-astro-cid-j7pv25f6>
        <div class="service-card__image" data-astro-cid-j7pv25f6>
          <img src="/Data-Record-6-scaled-e1736497744306.jpg" alt={t.card1Title} data-astro-cid-j7pv25f6 />
        </div>
        <div class="service-card__content" data-astro-cid-j7pv25f6>
          <h3 data-astro-cid-j7pv25f6>{t.card1Title}</h3>
          <p style="font-size:.8rem;color:var(--body-light);margin-bottom:.25rem">{t.card1TitleEN}</p>
          <p data-astro-cid-j7pv25f6>{t.card1Desc}</p>
          <p style="font-size:.8rem;color:var(--body-light);font-style:italic;margin-bottom:1rem">{t.card1DescEN}</p>
          <span class="service-card__link" data-astro-cid-j7pv25f6>{t.readMore}</span>
        </div>
      </a>
      <a href={servicesUrl} class="service-card" style="text-decoration:none;color:inherit" data-astro-cid-j7pv25f6>
        <div class="service-card__image" data-astro-cid-j7pv25f6>
          <img src="/Machine-1600x1200-1.jpg" alt={t.card2Title} data-astro-cid-j7pv25f6 />
        </div>
        <div class="service-card__content" data-astro-cid-j7pv25f6>
          <h3 data-astro-cid-j7pv25f6>{t.card2Title}</h3>
          <p style="font-size:.8rem;color:var(--body-light);margin-bottom:.25rem">{t.card2TitleEN}</p>
          <p data-astro-cid-j7pv25f6>{t.card2Desc}</p>
          <p style="font-size:.8rem;color:var(--body-light);font-style:italic;margin-bottom:1rem">{t.card2DescEN}</p>
          <span class="service-card__link" data-astro-cid-j7pv25f6>{t.readMore}</span>
        </div>
      </a>
      <a href={servicesUrl} class="service-card" style="text-decoration:none;color:inherit" data-astro-cid-j7pv25f6>
        <div class="service-card__image" data-astro-cid-j7pv25f6>
          <img src="/IMG_1283-1290x725.jpg" alt={t.card3Title} loading="lazy" data-astro-cid-j7pv25f6 />
        </div>
        <div class="service-card__content" data-astro-cid-j7pv25f6>
          <h3 data-astro-cid-j7pv25f6>{t.card3Title}</h3>
          <p style="font-size:.8rem;color:var(--body-light);margin-bottom:.25rem">{t.card3TitleEN}</p>
          <p data-astro-cid-j7pv25f6>{t.card3Desc}</p>
          <p style="font-size:.8rem;color:var(--body-light);font-style:italic;margin-bottom:1rem">{t.card3DescEN}</p>
          <span class="service-card__link" data-astro-cid-j7pv25f6>{t.readMore}</span>
        </div>
      </a>
    </div>
  </section>

  <section class="section section--dark" data-astro-cid-j7pv25f6>
    <div class="container" data-astro-cid-j7pv25f6>
      <div class="content-block" style="text-align:center" data-astro-cid-j7pv25f6>
        <span class="section-subtitle" style="color:rgba(255,255,255,.4)" data-astro-cid-j7pv25f6>{t.qualityTitleEN}</span>
        <h2 style="color:var(--white)" data-astro-cid-j7pv25f6>{t.qualityTitle}</h2>
        <p style="color:rgba(255,255,255,.65);max-width:700px;margin:0 auto;line-height:2;font-size:1.05rem" data-astro-cid-j7pv25f6>{t.qualityText}</p>
        <p style="color:rgba(255,255,255,.35);max-width:700px;margin:1.5rem auto 0;line-height:1.8;font-size:.9rem;font-style:italic" data-astro-cid-j7pv25f6>{t.qualityTextEN}</p>
      </div>
    </div>
  </section>
</Base>