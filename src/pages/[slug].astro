---
import { getEmDashEntry, getSeoMeta, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { detectLocale, SITE_TITLES } from "../utils/i18n";

const locale = detectLocale(Astro.url.pathname);
const slug = decodeSlug(Astro.params.slug);
if (!slug) return Astro.redirect("/404");

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug, { locale });
if (!page) return Astro.redirect("/404");
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const siteTitle = SITE_TITLES[locale];
const seo = getSeoMeta(page, {
  siteTitle,
  siteUrl: Astro.url.origin,
  path: `/${slug}`,
});
---

<Base
  title={seo.title}
  pageTitle={seo.ogTitle}
  description={seo.description}
  canonical={seo.canonical}
  content={{ collection: "pages", id: page.data.id, slug }}
>
  <section class="page-hero">
    <div class="container">
      <h1>{page.data.title}</h1>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="content-block">
        <PortableText value={page.data.content} />
      </div>
    </div>
  </section>

</Base>
