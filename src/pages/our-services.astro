---
import Base from "../layouts/Base.astro";
const t = {
  pageTitle: "服務內容",
  heroTitle: "Our Services",
  heroSub: "提供全面專業的機電工程服務",
  intro: "偉保是一間提供香港機電工程服務承建商，包括空調及通風及抽氣系統的安裝，改建維護及保養工程。",
  services: [
    {
      title: "項目管理",
      content: "偉保善長於提供專業設計和建設包括機械通風及空調，電氣，項目管理和業務連續性建構等項目，我們多年來所擁有的豐富經驗加上寶貴的工程技術溶入於設計創建方面尤其著名，而且當中更會確保整個設計及建築的可持續性及可維護性。通過所有設計及施工階段可以充分反映我們所應用到的專業知識。我們在提供創新的空調及通風系統，不僅提高建築物的運營效率和能源效益，同時也提升了客戶的生活和工作條件及所享受到的舒適經驗。",
      images: ["/P2130002-scaled-r2qah3twc4pdxr1klpcqiv90ma1zz44xd4cti3uin8.jpg"],
      alts: ["項目管理現場"]
    },
    {
      title: "維修及保養",
      content: "偉保工程有限公司專門提供於商業樓宇，辦公室，餐廳和住宅專業空調的定期保養，維修，銷售和安裝。",
      images: ["/Machine-1600x1200-1.jpg", "/Inspection-1-scaled-e1736498471313-1024x683.jpg"],
      alts: ["機組設備", "設備檢查維修"]
    },
    {
      title: "室內裝修",
      content: "我們善長於項目管理，提供由最初設計概念至項目完成的一站式服務，設計範疇包括住宅、餐廳及辦公室等。我們的工作是聆聽客戶之需要，提供適時及合乎經濟效益的方案。與客戶敲定設計方向及方案後，我們的設計及承建團隊會共同合作，於合理時間及成本控制內完成整個項目，而在過程的每一步，我們極重視與客戶的緊密溝通。",
      images: ["/panorama-3323163_1920.jpg", "/IMG_1588-1290x725.jpg", "/IMG_1283-1290x725.jpg"],
      alts: ["室內裝修全景", "裝修工程細節", "完工項目實景"]
    }
  ],
  summaryTitle: "服務項目摘要",
  summaryList: [
    "室內裝修項目", "水泵大修", "冷水機及冷卻塔大修", "風櫃更換工程",
    "年度檢查證書 (消防署)", "冷氣清洗服務", "電力安裝及 WR2 檢查",
    "冷水機安裝及更換", "通風系統安裝及更換", "VRV 安裝及更換", "凍倉安裝工程"
  ]
};
---
<Base title={t.pageTitle} description={t.heroSub}>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="section-subtitle">Services</span>
      <h1>{t.heroTitle}</h1>
      <p>{t.heroSub}</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="section" style="padding-bottom:0">
    <div class="container">
      <div class="section-title">
        <h2>What We Do</h2>
        <p class="section-desc">{t.intro}</p>
      </div>
    </div>
  </section>

  <!-- Service Cards with Images -->
  <section class="services-section">
    <div class="container">
      <div class="services-grid">
        {t.services.map(s => (
          <div class={`service-card${s.images.length > 1 ? ' service-card--wide' : ''}`}>
            <div class="service-card__image" style="cursor:pointer">
              {s.images.map((img, i) => (
                <a href={img} target="_blank"><img src={img} alt={s.alts[i]} loading="lazy" /></a>
              ))}
            </div>
            <div class="service-card__content">
              <h3>{s.title}</h3>
              <p>{s.content}</p>
            <a href="/our-services/" class="service-card__link">Read More &rarr;</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Summary List -->
  <section class="section section--dark">
    <div class="container">
      <div class="section-title" style="margin-bottom:2rem">
        <h2 style="color:#fff">{t.summaryTitle}</h2>
      </div>
      <div class="summary-grid">
        {t.summaryList.map(item => (
          <div class="summary-item">{item}</div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .service-card--wide .service-card__image {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .summary-item {
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 6px;
    color: #fff;
    font-size: .95rem;
    text-align: center;
    transition: background .3s, border-color .3s;
  }
  .summary-item:hover {
    background: rgba(255,255,255,.12);
    border-color: #fa4729;
  }
  @media (max-width: 1023px) {
    .services-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .summary-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 767px) {
    .services-grid { grid-template-columns: 1fr !important; }
    .summary-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
