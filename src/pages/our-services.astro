---
import Base from "../layouts/Base.astro";
const t = {
  pageTitle: "服務內容 | Our Services",
  heroTitle: "Our Services",
  heroTitleCN: "服務內容",
  heroSub: "提供全面專業的機電工程服務",
  heroSubEN: "Comprehensive Professional E&M Engineering Services",
  intro: "偉保是一間提供香港機電工程服務承建商，包括空調及通風及抽氣系統的安裝，改建維護及保養工程。",
  introEN: "VIEWCO is a Hong Kong E&M engineering service contractor, providing installation, alteration, maintenance and repair of air-conditioning, ventilation and exhaust systems.",
  services: [
    {
      title: "項目管理",
      titleEN: "Project Management",
      shortDesc: "超過四十年的專業經驗。",
      shortDescEN: "Over 40 years of professional experience.",
      images: ["/P2130002-scaled-r2qah3twc4pdxr1klpcqiv90ma1zz44xd4cti3uin8.jpg"],
      alts: ["Project Management"],
      link: "/services/engineering/"
    },
    {
      title: "維修及保養",
      titleEN: "Maintenance & Repair",
      shortDesc: "為客戶提供可靠的保障。",
      shortDescEN: "Reliable protection for our clients.",
      images: ["/Machine-1600x1200-1.jpg"],
      alts: ["Maintenance Equipment"],
      link: "/services/maintenance/"
    },
    {
      title: "室內裝修",
      titleEN: "Interior Fit-Out",
      shortDesc: "創造完美的室內空間與空調規劃。",
      shortDescEN: "Creating perfect interior spaces with AC planning.",
      images: ["/IMG_1283-1290x725.jpg"],
      alts: ["Completed Project"],
      link: "/services/indoor-furnish/"
    }
  ],
  summaryTitle: "服務項目摘要",
  summaryTitleEN: "Service Summary",
  summaryImgs: [
    "/IMG_1283-1290x725.jpg",
    "/P2130002-scaled-r2qah3twc4pdxr1klpcqiv90ma1zz44xd4cti3uin8.jpg",
    "/Machine-1600x1200-1.jpg",
    "/Inspection-1-scaled-e1736498471313-1024x683.jpg",
    "/Data-Record-6-scaled-e1736497744306.jpg",
    "/Viewco-website-HKSP-photo-wmremove.jpeg",
    "/2.-HSBC-Building-Fanling-150A-Auto-changeover-contactor-at-main-switchboard-2-r2qah3tvyz1urk7phe3dnb7p3lmutqvk1or5wqzh90.jpg",
    "/Viewco-website-bay-photo-wmremove.jpeg",
    "/WhatsApp-photo2024-10-0209.56.34_b0a3bcaa-e1728276578458.jpg",
    "/Viewco-website-HKSP-photo-wmremove-1.jpeg",
    "/oak-600-800.jpg"
  ],
  summaryList: [
    "🏗️ 室內裝修項目 Interior Fit-Out",
    "🔧 水泵大修 Pump Overhaul",
    "❄️ 冷水機及冷卻塔大修 Chiller & Cooling Tower Overhaul",
    "🌬️ 風櫃更換工程 AHU Replacement",
    "📋 年度檢查證書 (消防署) Annual Inspection (FSD)",
    "🧹 冷氣清洗服務 AC Cleaning",
    "⚡ 電力安裝及 WR2 檢查 Electrical & WR2",
    "🔄 冷水機安裝及更換 Chiller Installation",
    "💨 通風系統安裝及更換 Ventilation System",
    "🏢 VRV 安裝及更換 VRV Installation",
    "🧊 凍倉安裝工程 Cold Storage"
  ]
};
---
<Base title={t.pageTitle} description={t.heroSubEN}>
  <section class="page-hero" style="background:url(/Machine-1600x1200-1.jpg) center/cover">
    <div class="container">
      <span class="section-subtitle">Services</span>
      <h1>{t.heroTitle}</h1>
      <p style="font-size:1.3rem;font-weight:600;margin-bottom:.3rem">{t.heroTitleCN}</p>
      <p>{t.heroSub}</p>
      <p style="color:rgba(255,255,255,.5);font-size:.95rem">{t.heroSubEN}</p>
    </div>
  </section>

  <section class="section" style="padding-bottom:0">
    <div class="container">
      <div class="section-title">
        <h2>What We Do<span style="font-weight:400;font-size:.7em;color:var(--body-light);margin-left:.5rem">我們的工作</span></h2>
        <p class="section-desc">{t.intro}</p>
        <p class="section-desc" style="color:var(--body-light);font-size:.95rem;font-style:italic">{t.introEN}</p>
      </div>
    </div>
  </section>

  <section class="services-section">
    <div class="container">
      <div class="services-grid">
        {t.services.map((s, i) => (
          <a href={s.link} class="service-card" style="text-decoration:none;color:inherit">
            <div class="service-card__image">
              <img src={s.images[0]} alt={s.alts[0]} loading="lazy" />
            </div>
            <div class="service-card__content">
              <h3>{s.titleEN}</h3>
              <p style="font-weight:500;color:var(--navy);font-size:.9rem;margin-bottom:.25rem">{s.title}</p>
              <p style="font-size:.88rem">{s.shortDesc}</p>
              <p style="font-size:.82rem;color:var(--body-light);font-style:italic;margin-bottom:1rem">{s.shortDescEN}</p>
              <span class="service-card__link">閱讀更多 Read More →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="section-title" style="margin-bottom:2rem">
        <h2 style="color:var(--white)">{t.summaryTitle}</h2>
        <p style="color:var(--white-40);font-size:.9rem">{t.summaryTitleEN}</p>
      </div>
      <div class="summary-grid">
        {t.summaryList.map((item, i) => (
          <div class="summary-item">
            <img src={t.summaryImgs[i]} alt={item} style="width:100%;height:100px;object-fit:cover;display:block;border-radius:var(--radius) var(--radius) 0 0;margin-bottom:.5rem" loading="lazy" />
            <span style="font-size:.8rem">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .summary-grid { display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;max-width:var(--max-width);margin:0 auto }
  .summary-item { background:var(--white-06);border:1px solid var(--white-10);border-radius:var(--radius);color:var(--white);text-align:center;transition:all var(--transition);overflow:hidden;padding:0 0 .75rem 0 }
  .summary-item:hover { background:var(--white-10);border-color:var(--coral);transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.15) }
  @media(max-width:1023px){.services-grid{grid-template-columns:repeat(2,1fr)}.summary-grid{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:767px){.services-grid,.summary-grid{grid-template-columns:1fr}}
</style>
